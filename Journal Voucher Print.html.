    </div> 
   
    <div class="col-xs-4" style="margin-top: 50px; text-align: center;">
    <!--<hr class="hr1" style="border: 1px solid black; margin-top: 5px;"> -->
        <p style="margin-top: -20px; font-size: 12px;"><b>Manager</b></p>
    </div> 
    
    
    <div class="col-xs-4" style="margin-top: 50px; text-align: right;">
         <!--<hr class="hr1" style="border: 1px solid black; margin-top: 5px;"> -->
        <p style="margin-top:-20px; font-size: 12px;"><b>Accountant</b></p>
    </div>
    

    
</div>


<div style="display:flex; justify-content:flex-end; margin-top:40px;">
    <div style="text-align:center;"><p style="font-size:12px;"><b>Receiver's Signature</b></p>
        <hr style="border:1px solid black; margin-top:1px; width:150px;">
    </div>
</div>








