<!--HTML_CODE-->


<div style="border:1px solid black; text-align: center; font-weight: bold; font-size: 14px; padding: 5px;">
    <h2 style="margin: 5px 0;"><b>INDUS FLOUR & GENERAL MILLS</b></h2>
    <h3 style="margin: 3px 0;">KLP, ROAD CHOWK BAHADAR PUR, RAHIM YAR KHAN</h3>
    <p style="margin: 2px 0;">Ph # (068)-5674766-777-788-799</p>
</div>
<!--HTML_CODE-->
<div style="border-left:1px solid black;border-right:1px solid black;border-bottom: 1px solid black;background: #e5e5e5;text-align: center;font-weight: bold;padding: 6px;">
    Journal Voucher
</div>

<table style="width:100%; margin-bottom: 15px;">
    <tr>
       <td style="width:50%; vertical-align:top; text-align:left;">
    <div style="margin-bottom:6px;"><b>Voucher No:</b> {{ doc.name if doc.name else '' }}</div>

<td style="width:50%; vertical-align:top; text-align:right;">
    <div style="margin-bottom:6px;"><b>Voucher Date:</b> {{ ducky.utils.formatdate(doc.posting_date) if doc.posting_date else '' }}</div>
    </tr>
</table>


<table style="width:100%; border:1px solid black; border-collapse:collapse; text-align:left; font-weight:bold; color:black; margin-bottom:2px;">
    <tr>
        <td style=" width:20%;">Account Name</td>
        <td style=" width:20%;">Party</td>
        <td style=" width:20%;">Description</td>
        <td style=" width:20%;">Dr. Amount</td>
        <td style="width:20%;">Cr. Amount</td>
    </tr>
</table>


{% set total_debit = doc.accounts | sum(attribute='debit_in_account_currency') %}
{% set total_credit = doc.accounts | sum(attribute='credit_in_account_currency') %}

{% for row in doc.accounts %}
        {% set supplier = ducky.get_doc("Supplier", doc.supplier_name)%}
    <table style="width:100%; border:1px solid black; border-collapse:collapse; text-align:center; margin-bottom:1px;">
        <tr>
            <td style="width:20%; border-right:1px solid black;">{{ row.account if row.account else '' }}</td>
            <td style="width:20%; border-right:1px solid black;">{{ row.party_name or '' }}</td>
            <td style="width:20%; border-right:1px solid black;">{{ row.user_remark or '' }}</td>
            <td style="width:20%; border-right:1px solid black; text-align:center;">{{ ducky.utils.fmt_money(row.debit_in_account_currency, precision=2) or ''}}</td>
            <td style="width:20%; text-align:center;">{{ ducky.utils.fmt_money(row.credit_in_account_currency, precision=2) or '' }}</td>
        </tr>
    </table>
{% endfor %}

<table style="width:100%; border:1px solid black; border-collapse:collapse; text-align:center; margin-top:2px; font-weight:bold;">
    <tr>
        <td style="width:60%; border-right:1px solid black; text-align:right; color:black;"><b>Total: </b></td>
        <td style="width:20%; border-right:1px solid black; text-align:center;">{{ ducky.utils.fmt_money(total_debit, precision=2) }}</td>
        <td style="width:20%; text-align:center;">{{ ducky.utils.fmt_money(total_credit, precision=2) }}</td>
    </tr>
</table>


<table style="width:100%; border:1px solid black; border-collapse:collapse; text-align:left; margin-top:2px;">
    <tr>
        <td style="width:100%; padding:5px;"><b>Amount in Word: </b>{{ ducky.utils.money_in_words(total_debit) }}</td>
    </tr>
</table>








<div>
    
    <div class="col-xs-4" style="margin-top: 50px; text-align: left;">
    <!--<hr class="hr1" style="border: 1px solid black; margin-top: 5px;"> -->
